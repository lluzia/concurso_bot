htmlcov/

#################################################
# 🔐 GitHub / CI secrets leakage protection
#################################################

# arquivos de workflow temporários
*.tar
*.zip

# evitar arquivos acidentalmente gerados com envs
*.env.local
*.env.production
*.env.development

#################################################
# 📦 Node (caso futuramente adicione dashboard)
#################################################

node_modules/

#################################################
# 🚨 Segurança extra (IMPORTANTE)
#################################################

# backups de config com senha
config_backup.py
config_old.py


# qualquer arquivo com palavra "secret" ou "key"
*secret*
*apikey*
*token*
*password*

#################################################
# 🧠 Optional: evitar push acidental de datasets
#################################################

*.csv
*.xlsx
*.json.bak

